@startuml
!include plantuml.skin
!pragma layout smetana

rectangle "RestApiGateway" as gw
rectangle "Wait\n(wait-for-attachments)" as wait
rectangle "Notify\n(notify-attachment-received)" as notify

note "Status Gate\n(status transition)" as n1
rectangle "FetchDistributedMapCache" as fetch
rectangle "ReplaceText\n(COLLECTING_ATTACHMENTS → PROCESSED)" as replace
rectangle "PutDistributedMapCache" as put
rectangle "LogAttribute\n(gateway-merged)" as logMerged

rectangle "LogAttribute\n(gateway-attachment-done)" as logAttach

gw -down-> wait : upload
gw -down-> notify : attachments
wait -left-> wait : wait (self-loop)
wait -down-> fetch : success
wait -down-> fetch : expired
notify -down-> logAttach : success
fetch -down-> replace : success
replace -down-> put : success
put -down-> logMerged : success

n1 .. fetch
@enduml
