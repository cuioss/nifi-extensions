{
  "name": "nifi-cuioss-ui",
  "version": "1.0.0",
  "type": "module",
  "description": "Provides custom UI components for the CUIOSS NiFi extensions.",
  "main": "src/main/webapp/js/app.js",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "stylelint": "stylelint \"src/main/webapp/css/**/*.css\"",
    "stylelint:fix": "stylelint \"src/main/webapp/css/**/*.css\" --fix",
    "test": "NODE_ENV=test jest",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:coverage": "NODE_ENV=test jest --coverage --silent",
    "test:ci": "NODE_ENV=test jest --coverage --watchAll=false --passWithNoTests --silent"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cuioss/nifi-extensions.git"
  },
  "keywords": [
    "NiFi",
    "Custom UI",
    "JWT",
    "CUIOSS"
  ],
  "author": "CUIOSS",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/cuioss/nifi-extensions/issues"
  },
  "homepage": "https://github.com/cuioss/nifi-extensions#readme",
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@testing-library/jest-dom": "^6.4.0",
    "babel-jest": "^30.4.1",
    "eslint": "^10.7.0",
    "eslint-plugin-jest": "^29.15.4",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1"
  },
  "jest": {
    "verbose": false,
    "testEnvironment": "jest-environment-jsdom",
    "modulePathIgnorePatterns": [
      "<rootDir>/target/"
    ],
    "moduleDirectories": [
      "node_modules",
      "src/main/webapp/js"
    ],
    "moduleFileExtensions": [
      "js",
      "json"
    ],
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "testMatch": [
      "**/test/js/**/*.test.js"
    ],
    "collectCoverage": false,
    "coverageDirectory": "target/coverage",
    "coverageReporters": [
      "text",
      "html",
      "lcov"
    ],
    "coveragePathIgnorePatterns": [
      "<rootDir>/src/test/js/"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 75,
        "functions": 78,
        "lines": 80,
        "statements": 80
      },
      "src/main/webapp/js/app.js": {
        "branches": 60,
        "functions": 90,
        "lines": 95,
        "statements": 95
      }
    },
    "resetMocks": true,
    "clearMocks": true,
    "restoreMocks": true,
    "setupFiles": [
      "<rootDir>/src/test/js/jest.setup-fetch.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/test/js/jest.setup-dom.js"
    ]
  }
}
