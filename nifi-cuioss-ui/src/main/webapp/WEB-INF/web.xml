<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>MultiIssuerJWTTokenAuthenticator UI</display-name>

    <!-- Configure welcome files -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

    <!-- Configure mime types -->
    <mime-mapping>
        <extension>js</extension>
        <mime-type>application/javascript</mime-type>
    </mime-mapping>
    <mime-mapping>
        <extension>css</extension>
        <mime-type>text/css</mime-type>
    </mime-mapping>
    <!-- Only woff2 fonts are packaged into the WAR (see pom.xml packagingIncludes); the
         legacy woff/ttf/eot font formats and svg are not shipped, so their mime-mappings
         were dead and have been removed. -->
    <mime-mapping>
        <extension>woff2</extension>
        <mime-type>font/woff2</mime-type>
    </mime-mapping>

    <!-- Security Headers Filter - adds defense-in-depth response headers -->
    <filter>
        <filter-name>SecurityHeadersFilter</filter-name>
        <filter-class>de.cuioss.nifi.ui.servlets.SecurityHeadersFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>SecurityHeadersFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Processor ID Validation Filter -->
    <filter>
        <filter-name>ProcessorIdValidationFilter</filter-name>
        <filter-class>de.cuioss.nifi.ui.servlets.ProcessorIdValidationFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>ProcessorIdValidationFilter</filter-name>
        <url-pattern>/nifi-api/processors/jwt/*</url-pattern>
    </filter-mapping>

    <!-- JWT API Servlets -->
    <servlet>
        <servlet-name>JwtVerificationServlet</servlet-name>
        <servlet-class>de.cuioss.nifi.ui.servlets.JwtVerificationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>JwtVerificationServlet</servlet-name>
        <url-pattern>/nifi-api/processors/jwt/verify-token</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>JwksValidationServlet</servlet-name>
        <servlet-class>de.cuioss.nifi.ui.servlets.JwksValidationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>JwksValidationServlet</servlet-name>
        <url-pattern>/nifi-api/processors/jwt/validate-jwks-url</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>JwksValidationServlet</servlet-name>
        <url-pattern>/nifi-api/processors/jwt/validate-jwks-file</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>JwksValidationServlet</servlet-name>
        <url-pattern>/nifi-api/processors/jwt/validate-jwks-content</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ComponentInfoServlet</servlet-name>
        <servlet-class>de.cuioss.nifi.ui.servlets.ComponentInfoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ComponentInfoServlet</servlet-name>
        <url-pattern>/nifi-api/processors/jwt/component-info</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>GatewayProxyServlet</servlet-name>
        <servlet-class>de.cuioss.nifi.ui.servlets.GatewayProxyServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GatewayProxyServlet</servlet-name>
        <url-pattern>/nifi-api/processors/jwt/gateway/*</url-pattern>
    </servlet-mapping>

    <!-- Proxy context-path resolver - mapped OUTSIDE /nifi-api/processors/jwt/*
         so ProcessorIdValidationFilter does not require a processor-ID header.

         The honored context-path allowlist is derived by default from NiFi's
         nifi.web.proxy.context.path property. To override, add two servlet init-params
         named "allowedContextPaths" (comma-separated prefixes honored; empty honors
         nothing) and "trustAll" (when set to "true", any sanitized proxy prefix is
         honored) directly to the servlet element below; leave them absent so the
         servlet uses the NiFi-derived allowlist. -->
    <servlet>
        <servlet-name>ProxyContextPathServlet</servlet-name>
        <servlet-class>de.cuioss.nifi.ui.servlets.ProxyContextPathServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProxyContextPathServlet</servlet-name>
        <url-pattern>/nifi-api/context-path</url-pattern>
    </servlet-mapping>

</web-app>
